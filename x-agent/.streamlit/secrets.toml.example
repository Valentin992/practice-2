# Copy this to .streamlit/secrets.toml for local dev
# On Streamlit Cloud: paste each value into the Secrets UI

# Anthropic (Claude)
ANTHROPIC_API_KEY = "sk-ant-..."

# X (Twitter) — developer.x.com → your app → Keys and Tokens
# Requires OAuth 1.0a enabled, with Read+Write permissions
X_API_KEY        = "..."   # API Key
X_API_SECRET     = "..."   # API Key Secret
X_ACCESS_TOKEN   = "..."   # Access Token  (your @CristianVGB9 account)
X_ACCESS_SECRET  = "..."   # Access Token Secret

# Optional: needed for "GitHub commits" mode on private repos
GITHUB_TOKEN = "ghp_..."
